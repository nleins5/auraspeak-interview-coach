{
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Permissions-Policy", "value": "microphone=(*)" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/v1/:path*", "destination": "/api/index" },
    { "source": "/health", "destination": "/api/index" }
  ]
}
