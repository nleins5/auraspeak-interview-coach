# Local voice coach handoff env.
# Copy to .env in Antigravity, then fill real keys.

# Voice STT: use either Groq Whisper or Cloudflare Workers AI Whisper.
GROQ_API_KEY=
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=

# AI scoring provider. This project was smoke-tested with NVIDIA NIM.
NVIDIA_API_KEY_CUSTOM=
NVIDIA_MODEL_CUSTOM=meta/llama-3.3-70b-instruct

# Optional fallback chat providers from providers.json.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo-Free
HUGGINGFACE_API_KEY=
FREETHEAI_API_KEY=

# Local voice mode does not need database or gateway auth.
DISABLE_DATABASE=1
GATEWAY_SECRET=
REQUEST_TIMEOUT_S=8
MAX_RETRIES_PER_PROVIDER=0
ROUTING_MODE=chain

# Only required if you want full chat history/admin DB features.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/free_ai_gateway
